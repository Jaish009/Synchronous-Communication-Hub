/* ═══════════════════════════════════════════════════
   Landing Page — Minimalist Black Theme
   ═══════════════════════════════════════════════════ */

@import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap");

/* ── Reset & Base ── */
.land-page {
  --bg: #000000;
  --bg-alt: #070707;
  --text: #ffffff;
  --text-muted: #999999;
  --text-dim: #666666;
  --accent: #ffffff;
  --border: rgba(255, 255, 255, 0.06);
  --card-bg: rgba(255, 255, 255, 0.03);
  --card-hover: rgba(255, 255, 255, 0.06);

  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
    sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ═══════════════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════════════ */
.land-hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rem 2rem;
  position: relative;
  background: var(--bg);
}

/* subtle radial vignette */
.land-hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 80% 60% at 50% 40%,
    rgba(255, 255, 255, 0.015) 0%,
    transparent 70%
  );
  pointer-events: none;
}

.land-hero-inner {
  position: relative;
  z-index: 1;
  max-width: 740px;
  text-align: center;
  animation: heroFadeIn 1s ease-out both;
}

/* ── Brand ── */
.land-brand {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 2.5rem;
}

.land-brand-logo {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 0.5rem;
}

.land-brand-name {
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-muted);
}

/* ── Hero typography ── */
.land-hero-title {
  font-size: clamp(2.8rem, 6vw, 5rem);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 1.5rem;
  color: var(--text);
}

.land-hero-sub {
  font-size: 1.15rem;
  font-weight: 400;
  max-width: 540px;
  margin: 0 auto 2.5rem;
  color: var(--text-muted);
  line-height: 1.7;
}

/* ── CTA Button ── */
.land-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.9rem 2.4rem;
  font-size: 1rem;
  font-weight: 600;
  font-family: inherit;
  color: #000;
  background: #fff;
  border: none;
  border-radius: 999px;
  cursor: pointer;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.land-cta::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    transparent 40%,
    rgba(255, 255, 255, 0.5) 50%,
    transparent 60%
  );
  transform: translateX(-100%);
  transition: transform 0.6s ease;
}

.land-cta:hover::before {
  transform: translateX(100%);
}

.land-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 40px rgba(255, 255, 255, 0.12),
    0 10px 30px rgba(0, 0, 0, 0.4);
}

.land-cta-arrow {
  transition: transform 0.3s ease;
}

.land-cta:hover .land-cta-arrow {
  transform: translateX(4px);
}

/* ── Scroll hint ── */
.land-scroll-hint {
  margin-top: 4rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  color: var(--text-dim);
  font-size: 0.8rem;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  animation: scrollPulse 2.5s ease-in-out infinite;
}

.land-scroll-chevron {
  width: 20px;
  height: 20px;
  border-right: 2px solid var(--text-dim);
  border-bottom: 2px solid var(--text-dim);
  transform: rotate(45deg);
}

/* ═══════════════════════════════════════════════════
   SECTIONS
   ═══════════════════════════════════════════════════ */
.land-section {
  padding: 8rem 2rem;
  background: var(--bg);

  /* scroll-reveal setup */
  opacity: 0;
  transform: translateY(60px);
  transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
    transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.land-section--alt {
  background: var(--bg-alt);
}

.land-section.land-visible {
  opacity: 1;
  transform: translateY(0);
}

.land-section-inner {
  max-width: 720px;
  margin: 0 auto;
}

/* ── Badge ── */
.land-badge {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-muted);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 0.4rem 1.2rem;
  margin-bottom: 2rem;
  background: var(--card-bg);
}

/* ── Section typography ── */
.land-section-title {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 1.25rem;
  color: var(--text);
}

.land-section-desc {
  font-size: 1.05rem;
  color: var(--text-muted);
  line-height: 1.8;
  margin-bottom: 3rem;
}

/* ── Bullet Cards ── */
.land-bullets {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.land-bullet {
  display: flex;
  align-items: flex-start;
  gap: 1.2rem;
  padding: 1.25rem 1.5rem;
  border-radius: 1rem;
  border: 1px solid var(--border);
  background: var(--card-bg);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.land-bullet:hover {
  background: var(--card-hover);
  border-color: rgba(255, 255, 255, 0.1);
  transform: translateX(8px);
}

.land-bullet-icon {
  font-size: 1.5rem;
  flex-shrink: 0;
  width: 2.4rem;
  height: 2.4rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 0.6rem;
}

.land-bullet-title {
  display: block;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 0.2rem;
}

.land-bullet-text {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.6;
}

/* ═══════════════════════════════════════════════════
   FOOTER
   ═══════════════════════════════════════════════════ */
.land-footer {
  padding: 8rem 2rem 4rem;
  text-align: center;
  background: var(--bg);
  border-top: 1px solid var(--border);
}

.land-footer-title {
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
}

.land-footer-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  margin-bottom: 2.5rem;
}

.land-footer-copy {
  margin-top: 4rem;
  font-size: 0.8rem;
  color: var(--text-dim);
}

/* ═══════════════════════════════════════════════════
   ANIMATIONS
   ═══════════════════════════════════════════════════ */
@keyframes heroFadeIn {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scrollPulse {
  0%,
  100% {
    opacity: 0.5;
    transform: translateY(0);
  }
  50% {
    opacity: 1;
    transform: translateY(6px);
  }
}

/* ═══════════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════════ */
@media (max-width: 768px) {
  .land-hero {
    padding: 3rem 1.5rem;
  }

  .land-hero-sub {
    font-size: 1rem;
  }

  .land-section {
    padding: 5rem 1.5rem;
  }

  .land-section-desc {
    font-size: 0.95rem;
  }

  .land-bullet {
    padding: 1rem 1.2rem;
  }

  .land-footer {
    padding: 5rem 1.5rem 3rem;
  }

  .land-brand-name {
    font-size: 0.7rem;
  }
}

@media (max-width: 480px) {
  .land-hero-title {
    font-size: 2.2rem;
  }

  .land-section-title {
    font-size: 1.6rem;
  }

  .land-bullet {
    flex-direction: column;
    gap: 0.8rem;
  }
}
